# ── JanSetu AI — environment variables ─────────────────────────────
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored and must never be committed.

# Required for the AI civic companion (chat, scheme reasoning, document decoding).
# Get a key at https://openrouter.ai/keys  (a free/cheap model works fine).
# If omitted, the app still runs and returns a graceful demo fallback.
OPENROUTER_API_KEY=

# Optional: model override (defaults to a fast multilingual + vision model).
OPENROUTER_MODEL=google/gemini-2.5-flash

# Optional: web-search fallback for scheme queries not in the local dataset.
# Get a free key at https://tavily.com
TAVILY_API_KEY=

# ── Deployment (GitHub Actions CD → Vercel) ────────────────────────
# Set these as repository secrets, not here:
#   VERCEL_TOKEN, VERCEL_ORG_ID, VERCEL_PROJECT_ID
